# Kite Connect (Zerodha) — access token is regenerated daily via OAuth
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ICICI Breeze — session token from ICICI Markets mobile app
BREEZE_API_KEY=
BREEZE_API_SECRET=
BREEZE_SESSION_TOKEN=

# Output directory for CSV files
OUTPUT_DIR=./output

# Source selection: kite | breeze | auto
# auto = expired contracts use breeze, active contracts use breeze (preferred, has OI)
DEFAULT_SOURCE=auto

# Fetch window per contract: N days before expiry date
DAYS_BEFORE_EXPIRY=30

# Overwrite existing CSV files (true | false)
OVERWRITE=false

# Default underlying symbols for bulk fetch (JSON array)
UNDERLYINGS=["NIFTY","BANKNIFTY"]

# Path to NSE F&O bhavcopy directory (required for fetch-expiry and --all-strikes)
# Expected structure: {BHAVCOPY_DIR}/{YYYY}/{Mon}/{YYYYMMDD}_NSEFO.csv
BHAVCOPY_DIR=/Users/rbk/development/market_data/bhavcopy
